@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <div class="brand">Blutdruck Erfassung</div>
        <AuthorizeView>
            <Authorized>
                <div class="header-actions">
                    <span class="user-pill">@context.User.Identity?.Name</span>
                    <form method="post" action="/logout">
                        <button type="submit" class="btn-secondary">Abmelden</button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </header>

    <main>
        @Body
    </main>
</div>
