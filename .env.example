# Lokaler Vault
VAULT_DEV_ROOT_TOKEN_ID=change-me-vault-token
VAULT_KV_PATH=secret/blutdruck
LOCAL_VAULT_MOUNT=secret
LOCAL_VAULT_SECRET_PATH=blutdruck

# Azure SQL
AZURE_SQL_CONNECTION_STRING=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<db>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Azure Document Intelligence
OCR_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
OCR_API_KEY=<api-key>

# App Bootstrap Login
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
